[Unit]
Description=Nanosoft AI Frontend (Next.js)
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/ask-ai/ask-ai/nanosoft-ai-frontend
Environment="NODE_ENV=production"
ExecStart=/usr/bin/npm start -- -p 3000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
