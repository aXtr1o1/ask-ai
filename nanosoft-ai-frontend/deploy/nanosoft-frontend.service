
[Unit]
Description=Nanosoft AI Frontend (Next.js)
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/ask-ai/ask-ai/nanosoft-ai-frontend
Environment="NODE_ENV=development"
ExecStart=/usr/bin/npm run dev -- -p 3000 -H 0.0.0.0
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

