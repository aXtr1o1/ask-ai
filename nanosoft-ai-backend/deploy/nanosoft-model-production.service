[Unit]
Description=Nanosoft AI Model (FastAPI) — Production
After=network.target

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/var/www/html/ask-ai/nanosoft-ai-backend
ExecStart=/var/www/html/ask-ai/nanosoft-ai-backend/.venv/bin/uvicorn app.main:chatbot_app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
