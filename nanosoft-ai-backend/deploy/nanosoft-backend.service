[Unit]
Description=Nanosoft AI Backend (FastAPI)
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/ask-ai/ask-ai/nanosoft-ai-backend
Environment="PATH=/home/ubuntu/ask-ai/ask-ai/nanosoft-ai-backend/.venv/bin"
ExecStart=/home/ubuntu/ask-ai/ask-ai/nanosoft-ai-backend/.venv/bin/uvicorn app.api.main:db_api_app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
